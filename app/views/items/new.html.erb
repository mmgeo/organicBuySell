<% content_for :page_title, "Sell Item" %>

<div class="max-w-2xl mx-auto">
  <div class="bg-white shadow-sm rounded-lg p-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Sell Your Organic Produce</h1>
        <p class="text-gray-600 mt-1">List your fresh produce for sale</p>
      </div>
      <a href="<%= items_path %>" class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg transition-colors flex items-center space-x-2">
        <svg class="w-2 h-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        <span>Back to Items</span>
      </a>
    </div>
    <%= form_with model: @item, local: true, html: { id: "sell-form", class: "space-y-6" } do |f| %>
      <div>
        <%= f.label :farmer_id, "Farmer Profile", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.collection_select :farmer_id, @farmers, :id, :name, {prompt: "Select Farmer Profile"}, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-lime-400" %>
        <div class="text-xs text-gray-500 mt-1">
          <a href="<%= new_farmer_path %>" class="text-lime-600 hover:underline">Create new farmer profile</a>
        </div>
      </div>
      <div>
        <%= f.label :name, "Item Name", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.text_field :name, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400", id: "item_name" %>
        <div id="item_name-error" class="text-red-500 text-sm mt-1 hidden"></div>
      </div>
      <div>
        <%= f.label :item_type, "Type", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.select :item_type, ["Vegetable", "Fruit", "Homemade Product"], {}, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400" %>
      </div>
      <div class="flex gap-4">
        <div class="flex-1">
          <%= f.label :quantity, "Quantity", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.number_field :quantity, step: 0.01, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400", id: "item_quantity" %>
          <div id="item_quantity-error" class="text-red-500 text-sm mt-1 hidden"></div>
        </div>
        <div class="w-32">
          <%= f.label :quantity_unit, "Unit", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.select :quantity_unit, ["kg", "number"], {}, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400" %>
        </div>
      </div>
      <div>
        <%= f.label :price, "Price (₹)", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.number_field :price, step: 0.01, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400", id: "item_price" %>
        <div id="item_price-error" class="text-red-500 text-sm mt-1 hidden"></div>
      </div>
      <div>
        <%= f.label :phone, "Phone Number", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.telephone_field :phone, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400", id: "phone", maxlength: "15", pattern: "[0-9]+", title: "Please enter only digits" %>
        <div id="phone-error" class="text-red-500 text-sm mt-1 hidden"></div>
      </div>
      <div>
        <%= f.label :location, "Location", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <div class="flex gap-2">
          <%= f.text_field :location, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400", id: "location" %>
          <button type="button" id="get-location" class="bg-lime-500 hover:bg-lime-600 text-white px-3 py-2 rounded-lg shadow">Use Current Location</button>
        </div>
        <div id="location-error" class="text-red-500 text-sm mt-1 hidden"></div>
      </div>
      <%= f.hidden_field :latitude, id: "latitude" %>
      <%= f.hidden_field :longitude, id: "longitude" %>
      <div class="pt-4">
        <button type="submit" class="bg-lime-500 hover:bg-lime-600 transition text-white font-semibold px-6 py-3 rounded-lg w-full shadow-sm">List Item</button>
      </div>
    <% end %>
  </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
$(function() {
  // Form validation functions
  function validatePhone(phone) {
    // Remove any non-digit characters
    var cleanPhone = phone.replace(/\D/g, '');
    
    // Check if it's between 10-15 digits (common phone number lengths)
    if (cleanPhone.length < 10 || cleanPhone.length > 15) {
      return { valid: false, message: 'Phone number must be 10-15 digits long' };
    }
    
    // Check if it contains only digits
    if (!/^\d+$/.test(cleanPhone)) {
      return { valid: false, message: 'Phone number can only contain digits' };
    }
    
    return { valid: true, cleanValue: cleanPhone };
  }
  
  function validateRequired(field, fieldName) {
    var value = field.val().trim();
    if (!value) {
      return { valid: false, message: fieldName + ' is required' };
    }
    return { valid: true };
  }
  
  function validatePrice(price) {
    var value = parseFloat(price);
    if (isNaN(value) || value <= 0) {
      return { valid: false, message: 'Price must be a positive number' };
    }
    return { valid: true };
  }
  
  function validateQuantity(quantity) {
    var value = parseFloat(quantity);
    if (isNaN(value) || value <= 0) {
      return { valid: false, message: 'Quantity must be a positive number' };
    }
    return { valid: true };
  }
  
  function showError(fieldId, message) {
    $('#' + fieldId + '-error').text(message).removeClass('hidden');
    $('#' + fieldId).addClass('border-red-500').removeClass('border-gray-300');
  }
  
  function hideError(fieldId) {
    $('#' + fieldId + '-error').addClass('hidden');
    $('#' + fieldId).removeClass('border-red-500').addClass('border-gray-300');
  }
  
  // Phone number validation
  $('#phone').on('input', function() {
    var phone = $(this).val();
    var validation = validatePhone(phone);
    
    if (!validation.valid) {
      showError('phone', validation.message);
    } else {
      hideError('phone');
      // Auto-format: remove non-digits and update the field
      $(this).val(validation.cleanValue);
    }
  });
  
  // Required field validation
  $('#item_name').on('blur', function() {
    var validation = validateRequired($(this), 'Item name');
    if (!validation.valid) {
      showError('item_name', validation.message);
    } else {
      hideError('item_name');
    }
  });
  
  $('#item_price').on('blur', function() {
    var validation = validatePrice($(this).val());
    if (!validation.valid) {
      showError('item_price', validation.message);
    } else {
      hideError('item_price');
    }
  });
  
  $('#item_quantity').on('blur', function() {
    var validation = validateQuantity($(this).val());
    if (!validation.valid) {
      showError('item_quantity', validation.message);
    } else {
      hideError('item_quantity');
    }
  });
  
  $('#location').on('blur', function() {
    var validation = validateRequired($(this), 'Location');
    if (!validation.valid) {
      showError('location', validation.message);
    } else {
      hideError('location');
    }
  });
  
  // Form submission validation
  $('#sell-form').on('submit', function(e) {
    var isValid = true;
    
    // Validate all required fields
    var requiredFields = [
      { id: 'item_name', name: 'Item name' },
      { id: 'item_price', name: 'Price' },
      { id: 'item_quantity', name: 'Quantity' },
      { id: 'phone', name: 'Phone number' },
      { id: 'location', name: 'Location' }
    ];
    
    requiredFields.forEach(function(field) {
      var validation = validateRequired($('#' + field.id), field.name);
      if (!validation.valid) {
        showError(field.id, validation.message);
        isValid = false;
      }
    });
    
    // Validate phone number
    var phoneValidation = validatePhone($('#phone').val());
    if (!phoneValidation.valid) {
      showError('phone', phoneValidation.message);
      isValid = false;
    }
    
    // Validate price
    var priceValidation = validatePrice($('#item_price').val());
    if (!priceValidation.valid) {
      showError('item_price', priceValidation.message);
      isValid = false;
    }
    
    // Validate quantity
    var quantityValidation = validateQuantity($('#item_quantity').val());
    if (!quantityValidation.valid) {
      showError('item_quantity', quantityValidation.message);
      isValid = false;
    }
    
    if (!isValid) {
      e.preventDefault();
      // Scroll to first error
      $('html, body').animate({
        scrollTop: $('.border-red-500').first().offset().top - 100
      }, 500);
    }
  });
  
  // Auto-fill coordinates on page load
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(function(position) {
      $('#latitude').val(position.coords.latitude);
      $('#longitude').val(position.coords.longitude);
    }, function(error) {
      console.log('Geolocation error on page load:', error);
    });
  }

  $('#get-location').on('click', function() {
    var button = $(this);
    var originalText = button.text();
    button.text('Getting location...').prop('disabled', true);
    
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(function(position) {
        var lat = position.coords.latitude;
        var lon = position.coords.longitude;
        
        $('#latitude').val(lat);
        $('#longitude').val(lon);
        
        // Try to get address from coordinates using multiple services
        var locationFound = false;
        
        // First try Nominatim (OpenStreetMap)
        $.ajax({
          url: 'https://nominatim.openstreetmap.org/reverse',
          data: {
          lat: lat,
          lon: lon,
            format: 'json',
            zoom: 10,
            addressdetails: 1
          },
          dataType: 'jsonp',
          timeout: 8000,
          success: function(data) {
          if (data && data.display_name) {
              // Extract a more readable location name
              var locationName = '';
              if (data.address) {
                if (data.address.city) {
                  locationName = data.address.city;
                } else if (data.address.town) {
                  locationName = data.address.town;
                } else if (data.address.village) {
                  locationName = data.address.village;
                } else if (data.address.suburb) {
                  locationName = data.address.suburb;
                }
                
                if (data.address.state) {
                  locationName += ', ' + data.address.state;
                } else if (data.address.county) {
                  locationName += ', ' + data.address.county;
                }
              }
              
              if (locationName) {
                $('#location').val(locationName);
              } else {
                // Fallback to a shorter version of display_name
                var displayName = data.display_name;
                var parts = displayName.split(', ');
                if (parts.length > 2) {
                  $('#location').val(parts[0] + ', ' + parts[1] + ', ' + parts[parts.length - 1]);
          } else {
                  $('#location').val(displayName);
                }
              }
              locationFound = true;
            }
            button.text(originalText).prop('disabled', false);
          },
          error: function(xhr, status, error) {
            console.log('Nominatim geocoding error:', error);
            if (!locationFound) {
              // Try alternative approach - use coordinates but format nicely
              $('#location').val('Current Location (' + lat.toFixed(4) + ', ' + lon.toFixed(4) + ')');
            }
            button.text(originalText).prop('disabled', false);
          }
        });
      }, function(error) {
        console.log('Geolocation error:', error);
        var errorMessage = 'Unable to get location';
        switch(error.code) {
          case error.PERMISSION_DENIED:
            errorMessage = 'Location access denied. Please allow location access and try again.';
            break;
          case error.POSITION_UNAVAILABLE:
            errorMessage = 'Location information unavailable.';
            break;
          case error.TIMEOUT:
            errorMessage = 'Location request timed out.';
            break;
        }
        alert(errorMessage);
        button.text(originalText).prop('disabled', false);
      }, {
        enableHighAccuracy: true,
        timeout: 10000,
        maximumAge: 60000
      });
    } else {
      alert('Geolocation is not supported by this browser.');
      button.text(originalText).prop('disabled', false);
    }
  });
});
</script>