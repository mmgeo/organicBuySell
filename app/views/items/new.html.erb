<div class="min-h-screen bg-gradient-to-br from-blue-50 to-green-50 flex items-center justify-center py-8">
  <div class="absolute left-8 top-8">
    <a href="<%= items_path %>" class="bg-lime-500 hover:bg-lime-600 text-white rounded-full px-4 py-2 shadow flex items-center gap-2">
      &#8592; <span class="hidden sm:inline">Back</span>
    </a>
  </div>
  <div class="bg-white shadow-lg rounded-lg p-8 w-full max-w-lg">
    <h1 class="text-3xl font-extrabold text-lime-700 mb-6 text-center">Sell Your Organic Produce</h1>
    <%= form_with model: @item, local: true, html: { id: "sell-form", class: "space-y-6" } do |f| %>
      <div>
        <%= f.label :name, "Item Name", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.text_field :name, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400" %>
      </div>
      <div>
        <%= f.label :item_type, "Type", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.select :item_type, ["Vegetable", "Fruit"], {}, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400" %>
      </div>
      <div class="flex gap-4">
        <div class="flex-1">
          <%= f.label :quantity, "Quantity", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.number_field :quantity, step: 0.01, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400" %>
        </div>
        <div class="w-32">
          <%= f.label :quantity_unit, "Unit", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.select :quantity_unit, ["kg", "number"], {}, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400" %>
        </div>
      </div>
      <div>
        <%= f.label :price, "Price (₹)", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.number_field :price, step: 0.01, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400" %>
      </div>
      <div>
        <%= f.label :phone, "Phone Number", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= f.telephone_field :phone, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400" %>
      </div>
      <div>
        <%= f.label :location, "Location", class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <div class="flex gap-2">
          <%= f.text_field :location, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-400", id: "location" %>
          <button type="button" id="get-location" class="bg-lime-500 hover:bg-lime-600 text-white px-3 py-2 rounded-lg shadow">Use Current Location</button>
        </div>
      </div>
      <%= f.hidden_field :latitude, id: "latitude" %>
      <%= f.hidden_field :longitude, id: "longitude" %>
      <div class="pt-2">
        <button type="submit" class="bg-lime-500 hover:bg-lime-600 transition text-white font-semibold px-6 py-2 rounded-lg w-full shadow">List Item</button>
      </div>
    <% end %>
  </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
$(function() {
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(function(position) {
      $('#latitude').val(position.coords.latitude);
      $('#longitude').val(position.coords.longitude);
    });
  }

  $('#get-location').on('click', function() {
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(function(position) {
        // Use Nominatim reverse geocoding
        var lat = position.coords.latitude;
        var lon = position.coords.longitude;
        $('#latitude').val(lat);
        $('#longitude').val(lon);
        $.get('https://nominatim.openstreetmap.org/reverse', {
          lat: lat,
          lon: lon,
          format: 'json'
        }, function(data) {
          if (data && data.display_name) {
            $('#location').val(data.display_name);
          } else {
            $('#location').val(lat + ', ' + lon);
          }
        });
      });
    } else {
      alert('Geolocation is not supported by this browser.');
    }
  });
});
</script>