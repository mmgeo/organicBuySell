<body class="prose">

<div class="align-center">

<div class="flex items-center justify-center gap-4 mb-8">
  <%= image_tag 'organic_logo.png', alt: 'Organic Market Logo', class: 'h-16 w-16 object-contain' %>
  <h1 class="text-3xl font-extrabold text-center text-lime-600">Organic Farmer's Market</h1>
</div>

<div class="flex justify-center mb-4">
  <a href="<%= new_item_path %>"
     class="bg-lime-500 hover:bg-lime-600 text-white w-12 h-12 flex items-center justify-center rounded-full shadow text-2xl focus:outline-none focus:ring-2 focus:ring-blue-400"
     title="Sell Something">
    <span class="sr-only">Sell Something</span>
    +
  </a>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 mt-6">
  <% @items.each do |item| %>
    <div class="bg-white rounded-lg shadow-lg overflow-hidden flex flex-col p-6">
      <h2 class="text-xl font-bold text-gray-800 mb-1"><%= item.name %></h2>
      <p class="text-sm text-gray-500 mb-2"><%= item.item_type %></p>
      <p class="mb-1"><span class="font-semibold">Quantity:</span> <%= item.quantity %> <%= item.quantity_unit %></p>
      <p class="mb-1"><span class="font-semibold">Price:</span> ₹<%= item.price %></p>
      <p class="mb-1"><span class="font-semibold">Phone:</span> <a href="tel:<%= item.phone %>" class="text-blue-500 underline"><%= item.phone %></a></p>
      <p class="mb-1"><span class="font-semibold">Location:</span> <%= item.location %></p>
    </div>
  <% end %>
</div>

</div>
</body>
