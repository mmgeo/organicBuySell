<% content_for :page_title, "Browse Items" %>

<div class="space-y-6">
  <!-- Header with stats -->
  <div class="bg-white rounded-lg shadow-sm p-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Organic Market</h1>
        <p class="text-gray-600 mt-1">Fresh produce from local farmers</p>
      </div>
      <div class="flex items-center space-x-4">
        <div class="text-center">
          <div class="text-2xl font-bold text-lime-600"><%= @items.count %></div>
          <div class="text-sm text-gray-500">Items Available</div>
        </div>
        <a href="<%= new_item_path %>" class="bg-lime-500 hover:bg-lime-600 text-white px-4 py-2 rounded-lg shadow-sm transition-colors flex items-center space-x-2">
          <svg class="w-2 h-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
          <span>Sell Item</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-lg shadow-sm p-4">
    <div class="flex items-center space-x-4">
      <div class="flex items-center space-x-2">
        <span class="text-sm font-medium text-gray-700">Filter by:</span>
        <a href="<%= root_path %>" class="px-3 py-1 text-sm rounded-full <%= 'bg-lime-100 text-lime-700' unless params[:type] %> hover:bg-gray-100 transition-colors">All</a>
        <a href="<%= root_path %>?type=vegetable" class="px-3 py-1 text-sm rounded-full <%= 'bg-lime-100 text-lime-700' if params[:type] == 'vegetable' %> hover:bg-gray-100 transition-colors">Vegetables</a>
        <a href="<%= root_path %>?type=fruit" class="px-3 py-1 text-sm rounded-full <%= 'bg-lime-100 text-lime-700' if params[:type] == 'fruit' %> hover:bg-gray-100 transition-colors">Fruits</a>
        <a href="<%= root_path %>?type=homemade" class="px-3 py-1 text-sm rounded-full <%= 'bg-lime-100 text-lime-700' if params[:type] == 'homemade' || params[:type] == 'homemade product' || params[:type] == 'homemade_products' || params[:type] == 'homemadeproducts' %> hover:bg-gray-100 transition-colors">Homemade Products</a>
      </div>
    </div>
  </div>

  <!-- Items Grid -->
  <% if @items.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% @items.each do |item| %>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
          <div class="p-6">
            <div class="flex items-start justify-between mb-3">
              <div class="flex-1">
                <h3 class="text-lg font-semibold text-gray-900 mb-1"><%= item.name %></h3>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= item.item_type == 'Vegetable' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                  <%= item.item_type %>
                </span>
              </div>
            </div>
            
            <div class="space-y-2 text-sm text-gray-600">
              <div class="flex items-center">
                <svg class="w-2 h-2 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path>
                </svg>
                <span><%= item.quantity %> <%= item.quantity_unit %></span>
              </div>
              
              <div class="flex items-center">
                <svg class="w-2 h-2 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                </svg>
                <span class="font-semibold text-gray-900">₹<%= item.price %></span>
              </div>
              
              <div class="flex items-center">
                <svg class="w-2 h-2 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
                <a href="tel:<%= item.phone %>" class="text-lime-600 hover:text-lime-700 font-medium"><%= item.phone %></a>
              </div>
              
              <div class="flex items-start">
                <svg class="w-2 h-2 mr-2 text-gray-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <span class="text-gray-600"><%= item.location %></span>
              </div>

              <% if item.farmer %>
                <div class="mt-4 p-3 bg-lime-50 rounded border border-lime-100">
                  <div class="flex items-center gap-3 mb-2">
                    <% if item.farmer.photo_id.attached? %>
                      <%= image_tag item.farmer.photo_id.variant(resize_to_limit: [40, 40]), class: "w-10 h-10 rounded-full object-cover border border-gray-200" %>
                    <% end %>
                    <div>
                      <div class="font-semibold text-lime-700"><%= item.farmer.name %></div>
                      <div class="text-xs text-gray-500"><%= item.farmer.farm_location %></div>
                      <% if item.farmer.is_organic %>
                        <span class="inline-block text-xs text-green-700 bg-green-100 rounded px-2 py-0.5 mt-1">Certified Organic</span>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>

            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow-sm p-12 text-center">
      <svg class="w-8 h-8 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
      </svg>
      <h3 class="text-lg font-medium text-gray-900 mb-2">No items available</h3>
      <p class="text-gray-500 mb-6">Be the first to list your organic produce!</p>
      <a href="<%= new_item_path %>" class="bg-lime-500 hover:bg-lime-600 text-white px-4 py-2 rounded-lg shadow-sm transition-colors">
        List Your First Item
      </a>
    </div>
  <% end %>
</div>
