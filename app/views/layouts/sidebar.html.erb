<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Organic Buy Sell" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="icon" href="/favicon.png" type="image/png" />

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <div class="flex h-screen">
      <!-- Sidebar -->
      <div class="w-64 bg-white shadow-lg fixed h-full z-30">
        <!-- Logo/Brand -->
        <div class="p-6 border-b border-gray-200">
          <div class="flex items-center space-x-3">
            <div class="w-8 h-8 bg-lime-500 rounded-lg flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h1 class="text-xl font-bold text-gray-800">Organic Market</h1>
          </div>
        </div>

        <!-- Navigation -->
        <nav class="mt-6">
          <div class="px-4 space-y-2">
            <!-- Home -->
            <a href="<%= root_path %>" class="flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-lime-50 hover:text-lime-700 transition-colors <%= 'bg-lime-100 text-lime-700 border-r-2 border-lime-500' if current_page?(root_path) %>">
              <svg class="w-3 h-3 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
              </svg>
              <span class="font-medium">Browse Items</span>
            </a>

            <!-- Sell Item -->
            <a href="<%= new_item_path %>" class="flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-lime-50 hover:text-lime-700 transition-colors <%= 'bg-lime-100 text-lime-700 border-r-2 border-lime-500' if current_page?(new_item_path) %>">
              <svg class="w-3 h-3 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
              </svg>
              <span class="font-medium">Sell Item</span>
            </a>

            <!-- Add Farmer Profile -->
            <a href="<%= new_farmer_path %>" class="flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-blue-50 hover:text-blue-700 transition-colors <%= 'bg-blue-100 text-blue-700 border-r-2 border-blue-500' if current_page?(new_farmer_path) %>">
              <svg class="w-3 h-3 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="font-medium">Add Farmer Profile</span>
            </a>

            <!-- Categories -->
            <div class="pt-4">
              <h3 class="px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Categories</h3>
              <div class="mt-2 space-y-1">
                <a href="<%= root_path %>?type=vegetable" class="flex items-center px-4 py-2 text-sm text-gray-600 rounded-lg hover:bg-gray-100 transition-colors">
                  <div class="w-2 h-2 bg-green-500 rounded-full mr-3"></div>
                  Vegetables
                </a>
                <a href="<%= root_path %>?type=fruit" class="flex items-center px-4 py-2 text-sm text-gray-600 rounded-lg hover:bg-gray-100 transition-colors">
                  <div class="w-2 h-2 bg-red-500 rounded-full mr-3"></div>
                  Fruits
                </a>
                <a href="<%= root_path %>?type=homemade" class="flex items-center px-4 py-2 text-sm text-gray-600 rounded-lg hover:bg-gray-100 transition-colors">
                  <div class="w-2 h-2 bg-yellow-500 rounded-full mr-3"></div>
                  Homemade Products
                </a>
              </div>
            </div>

            <!-- Quick Actions -->
            <div class="pt-4">
              <h3 class="px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Quick Actions</h3>
              <div class="mt-2 space-y-1">
                <button onclick="getCurrentLocation()" class="w-full flex items-center px-4 py-2 text-sm text-gray-600 rounded-lg hover:bg-gray-100 transition-colors">
                  <svg class="w-2 h-2 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  Find Near Me
                </button>
              </div>
            </div>
          </div>
        </nav>

        <!-- Footer -->
        <div class="absolute bottom-0 w-full p-4 border-t border-gray-200">
          <div class="text-center">
            <p class="text-xs text-gray-500">© 2024 Organic Market</p>
            <p class="text-xs text-gray-400 mt-1">Fresh from farm to table</p>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="flex-1 ml-64">
        <!-- Top Bar -->
        <div class="bg-white shadow-sm border-b border-gray-200 px-6 py-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-4">
              <h2 class="text-xl font-semibold text-gray-800">
                <%= content_for(:page_title) || "Organic Market" %>
              </h2>
            </div>
            
            <!-- Notifications/User Menu -->
            <div class="flex items-center space-x-4">
              <!-- Search -->
              <div class="relative">
                <input type="text" placeholder="Search items..." class="w-64 pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-lime-400 focus:border-transparent">
                <svg class="absolute left-3 top-2.5 w-2 h-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
              </div>

              <!-- Notifications -->
              <button class="p-2 text-gray-400 hover:text-gray-600 transition-colors">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-5 5v-5z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Page Content -->
        <main class="p-6">
          <% if notice %>
            <div class="mb-4 p-4 bg-green-100 border border-green-400 text-green-700 rounded-lg">
              <%= notice %>
            </div>
          <% end %>

          <% if alert %>
            <div class="mb-4 p-4 bg-red-100 border border-red-400 text-red-700 rounded-lg">
              <%= alert %>
            </div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    </div>

    <script>
      function getCurrentLocation() {
        if (navigator.geolocation) {
          navigator.geolocation.getCurrentPosition(function(position) {
            // Redirect to items with location filter
            window.location.href = '<%= root_path %>?lat=' + position.coords.latitude + '&lng=' + position.coords.longitude;
          }, function(error) {
            alert('Unable to get your location. Please allow location access.');
          });
        } else {
          alert('Geolocation is not supported by this browser.');
        }
      }
    </script>
  </body>
</html> 