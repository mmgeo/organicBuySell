<div class="max-w-xl mx-auto bg-white shadow rounded-lg p-8 mt-10">
  <h1 class="text-2xl font-bold mb-6 text-lime-700 text-center">Create Farmer Profile</h1>
  <%= form_with model: @farmer, local: true, html: { multipart: true, class: "space-y-6" } do |f| %>
    <div>
      <%= f.label :name, "Farmer Name", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-lime-400" %>
    </div>
    <div>
      <%= f.label :photo_id, "Photo ID (Upload)", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.file_field :photo_id, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-lime-400" %>
    </div>
    <div>
      <%= f.label :farm_location, "Farm Location", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.text_field :farm_location, class: "border border-gray-300 rounded-lg px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-lime-400" %>
    </div>
    <div class="flex items-center">
      <%= f.check_box :is_organic, class: "mr-2" %>
      <%= f.label :is_organic, "Certified Organic?", class: "text-sm font-semibold text-gray-700" %>
    </div>
    <div class="pt-4">
      <%= f.submit "Submit", class: "bg-lime-500 hover:bg-lime-600 text-white font-semibold px-6 py-2 rounded-lg w-full shadow" %>
    </div>
  <% end %>
</div> 